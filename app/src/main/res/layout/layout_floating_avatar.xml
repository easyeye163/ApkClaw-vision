<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="120dp"
    android:layout_height="120dp">

    <!-- Video renderer container -->
    <FrameLayout
        android:id="@+id/avatarVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Rounded mask overlay - clips video to circle -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_avatar_circle_mask" />

    <!-- Status indicator (shown when disconnected/error/connecting) -->
    <ImageView
        android:id="@+id/ivAvatarStatus"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:contentDescription="@string/cd_app_logo"
        android:src="@drawable/ic_launcher"
        android:visibility="visible" />

    <!-- Speaking indicator (small dot at bottom) -->
    <View
        android:id="@+id/speakingIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_dot_speaking"
        android:visibility="gone" />

</FrameLayout>
